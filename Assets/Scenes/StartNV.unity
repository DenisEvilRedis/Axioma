    speakerPortrait: 0
    bodyText: "\u041C\u0430\u043A\u0441 \u0432\u0445\u043E\u0434\u0438\u0442 \u0432
      \u043C\u0440\u0430\u043C\u043E\u0440\u043D\u0443\u044E \u0432\u0430\u043D\u043D\u0443\u044E.
