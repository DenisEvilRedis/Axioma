    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u041F\u0430\u043B\u044C\u0446\u044B \u0440\u0430\u0432\u043D\u043E\u0434\u0443\u0448\u043D\u043E
      \u0441\u043A\u043E\u043B\u044C\u0437\u043D\u0443\u043B\u0438 \u043C\u0438\u043C\u043E
      \u0440\u044F\u0434\u043E\u0432 \u0434\u043E\u0440\u043E\u0433\u0438\u0445 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0445
      \u043A\u043E\u0441\u0442\u044E\u043C\u043E\u0432 \u2014 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
