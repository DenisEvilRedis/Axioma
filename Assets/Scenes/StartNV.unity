    mode: 0
    speaker: "\u0412\u0435\u0440\u0430"
    speakerPortrait: 4
    bodyText: "\u2014 \u0418\u0437\u0432\u0438\u043D\u0438, \u0431\u0440\u0430\u0442.
      \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0431\u0435\u0437 \u043C\u0435\u043D\u044F.
      \u0423 \u043C\u0435\u043D\u044F \u044D\u0444\u0438\u0440.\r\n\u041E\u043D \u0441\u0431\u0440\u043E\u0441\u0438\u043B
      \u0432\u044B\u0437\u043E\u0432, \u043D\u0435 \u0434\u043E\u0436\u0438\u0434\u0430\u044F\u0441\u044C
      \u043E\u0442\u0432\u0435\u0442\u0430. \u0429\u0435\u043B\u0447\u043E\u043A
      \u043A\u043D\u043E\u043F\u043A\u0438 \u043E\u0442\u0441\u0435\u043A \u043F\u0440\u043E\u0448\u043B\u043E\u0435.
      \u041D\u0430\u0437\u0430\u0434 \u0434\u043E\u0440\u043E\u0433\u0438 \u043D\u0435\u0442.
      \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043E\u043D \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442
      \u0433\u043B\u044F\u043D\u0435\u0446."
