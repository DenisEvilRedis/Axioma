      \u0441 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u043D\u0443\u044E -
      \u0438 \u0441\u0435\u043C\u043D\u0430\u0434\u0446\u0430\u0442\u044C \u0443\u0432\u0435\u0434\u043E\u043C\u043B\u0435\u043D\u0438\u0439,
      \u043A\u0430\u043A \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440."
