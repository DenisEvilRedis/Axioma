  - beatId: scene3_lyokha_call
    mode: 0
    speaker: "\u0412\u0435\u0440\u0430"
    speakerPortrait: 4
    bodyText: "\u0422\u0443\u0442 \u0436\u0435 \u0440\u0430\u0437\u0434\u0430\u0451\u0442\u0441\u044F
      \u0437\u0432\u043E\u043D\u043E\u043A \u0438\u0437 \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E.\n-
      \u041C\u0430\u043A\u0441? \u042D\u0442\u043E \u0412\u0435\u0440\u0430. \u0421\u0442\u043E\u044E
      \u0441\u0435\u0439\u0447\u0430\u0441 \u0437\u0430 \u0441\u0442\u043E\u0439\u043A\u043E\u0439,
      \u0441\u043C\u043E\u0442\u0440\u044E \u043D\u0430 \u043F\u0443\u0441\u0442\u0443\u044E
      \u0441\u0446\u0435\u043D\u0443\u2026 \u0423 \u043D\u0430\u0441 \u0442\u0443\u0442
      \u0432\u0441\u0451 \u043F\u043E-\u0441\u0442\u0430\u0440\u043E\u043C\u0443,
      \u0434\u0430\u0436\u0435 \u0442\u0440\u0435\u0449\u0438\u043D\u044B \u043D\u0430
      \u0441\u0442\u0435\u043D\u0430\u0445 \u0432\u0441\u0451 \u0442\u0435 \u0436\u0435.
      \u0422\u043E\u043B\u044C\u043A\u043E \u0442\u0432\u043E\u0435\u0433\u043E \u0433\u043E\u043B\u043E\u0441\u0430
      \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442. \u0423\u0441\u0442\u0440\u043E\u0438\u0448\u044C
      \u043D\u0430\u043C \u0432\u0435\u0447\u0435\u0440, \u043A\u0430\u043A \u0440\u0430\u043D\u044C\u0448\u0435?"
