    speakerPortrait: 2
    bodyText: "\u0413\u043E\u043B\u043E\u0441 \u0410\u0440\u0442\u0443\u0440\u0430
      \u0432\u043B\u0435\u0442\u0430\u0435\u0442 \u0432 \u0442\u0438\u0448\u0438\u043D\u0443
      \u0431\u043E\u0434\u0440\u043E, \u043D\u0430\u043F\u043E\u0440\u0438\u0441\u0442\u043E
      \u0438 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u043D\u0435\u0432\u044B\u043D\u043E\u0441\u0438\u043C\u043E."
