  - beatId: scene7_lyokha_02
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u0421 \u0435\u0434\u0432\u0430 \u0441\u043B\u044B\u0448\u043D\u044B\u043C
      \u0441\u043A\u0440\u0438\u043F\u043E\u043C \u043D\u0430 \u043F\u043B\u0435\u0447\u0438
      \u043B\u0435\u0433\u043B\u0430 \u0441\u0442\u0430\u0440\u0430\u044F \u0434\u043E\u0431\u0440\u0430\u044F
      \u043A\u043E\u0441\u0443\u0445\u0430. \u0422\u044F\u0436\u0435\u043B\u0430\u044F,
      \u043F\u043E\u0442\u0435\u0440\u0442\u0430\u044F, \u0445\u0440\u0430\u043D\u044F\u0449\u0430\u044F
      \u0432\u044A\u0435\u0432\u0448\u0438\u0439\u0441\u044F \u0437\u0430\u043F\u0430\u0445
      \u0442\u0430\u0431\u0430\u043A\u0430 \u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
      \u0441\u0432\u043E\u0431\u043E\u0434\u044B."
