      \u041D\u043E\u043C\u0435\u0440 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
      \u0442\u0430\u043A, \u0431\u0443\u0434\u0442\u043E \u0437\u0434\u0435\u0441\u044C
      \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0438 \u043D\u0435 \u0432\u0435\u0447\u0435\u0440\u0438\u043D\u043A\u0443,
      \u0430 \u044D\u0432\u0430\u043A\u0443\u0430\u0446\u0438\u044E."
