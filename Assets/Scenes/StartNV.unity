  beats:
  - beatId: scene3_enter
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u041D\u0430 \u043A\u0443\u0445\u043D\u0435 \u043C\u0438\u0433\u0430\u0435\u0442
      \u0442\u0435\u043B\u0435\u0444\u043E\u043D. \u041C\u0440\u0430\u043C\u043E\u0440\u043D\u0430\u044F
      \u0441\u0442\u043E\u0439\u043A\u0430, \u043A\u043E\u0444\u0435\u043C\u0430\u0448\u0438\u043D\u0430
