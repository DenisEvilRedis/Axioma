    speaker: "\u0423\u0442\u0440\u043E"
    speakerPortrait: 0
    bodyText: "\u0421\u0432\u0435\u0442 \u0431\u044C\u0435\u0442 \u043F\u043E \u0433\u043B\u0430\u0437\u0430\u043C,
