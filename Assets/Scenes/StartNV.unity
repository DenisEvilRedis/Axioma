      \u042F \u0443\u0441\u0442\u0430\u043B \u0442\u043E\u0440\u0433\u043E\u0432\u0430\u0442\u044C
      \u043B\u0438\u0446\u043E\u043C. \u0421\u0435\u0433\u043E\u0434\u043D\u044F
      \u044F \u0438\u0433\u0440\u0430\u044E \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445.\r\n\u041F\u0440\u043E\u0434\u044E\u0441\u0435\u0440
      \u043D\u0430 \u0442\u043E\u043C \u043A\u043E\u043D\u0446\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u0430
      \u0441\u043E\u0440\u0432\u0430\u043B\u0441\u044F \u043D\u0430 \u0438\u0441\u0442\u0435\u0440\u0438\u0447\u043D\u044B\u0439
      \u043A\u0440\u0438\u043A, \u0443\u0433\u0440\u043E\u0436\u0430\u044F \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u0442\u044C
      \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0443. \u041E\u043D
      \u043D\u0435 \u0441\u043B\u0443\u0448\u0430\u043B, \u043E\u0431\u043E\u0440\u0432\u0430\u0432
      \u0441\u0432\u044F\u0437\u044C \u043D\u0430 \u043F\u043E\u043B\u0443\u0441\u043B\u043E\u0432\u0435.
      \u0422\u0430\u043C, \u0432 \u043F\u0440\u043E\u043A\u0443\u0440\u0435\u043D\u043D\u043E\u043C
      \u0431\u0430\u0440\u0435, \u0435\u0433\u043E \u0436\u0434\u0430\u043B\u0430
      \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F \u0436\u0438\u0437\u043D\u044C."
    background: {fileID: 21300000, guid: dfa4a0759d56379448af803e52d6028e, type: 3}
    musicCueId: 
    stopMusic: 1
    nextBeatId: scene_Final_Honesty
