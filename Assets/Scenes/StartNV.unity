    speakerPortrait: 0
    bodyText: "\u041E\u043D \u0434\u043E\u0441\u0442\u0430\u0435\u0442 \u0440\u043E\u043C-\u043A\u043E\u043B\u0443.
      \u0412\u043A\u0443\u0441 \u0431\u044C\u0435\u0442 \u043F\u0430\u043C\u044F\u0442\u044C\u044E
      \u0441\u0438\u043B\u044C\u043D\u0435\u0435, \u0447\u0435\u043C \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u044C:
      \u0442\u0440\u0430\u0441\u0441\u0430, \u0433\u0430\u0441\u0442\u0440\u043E\u043B\u0438,
      \u0437\u0430\u0434\u043D\u0435\u0435 \u0441\u0438\u0434\u0435\u043D\u044C\u0435
      \u0441\u0442\u0430\u0440\u043E\u0439 \"\u0431\u0443\u0445\u0430\u043D\u043A\u0438\"."
    background: {fileID: 21300000, guid: 0289863cf1d04ce4884899ddb9fb2669, type: 3}
