  - beatId: scene7_answer_arthur
    mode: 0
    speaker: "\u0410\u0440\u0442\u0443\u0440"
    speakerPortrait: 2
    bodyText: "\u041C\u0430\u043A\u0441! \u0414\u043E \u0441\u0442\u0430\u0440\u0442\u0430
      \u0441\u044A\u0435\u043C\u043E\u043A \u0432\u0441\u0435\u0433\u043E \u0447\u0430\u0441.
      \u041F\u0430\u0432\u0438\u043B\u044C\u043E\u043D \u0433\u043E\u0442\u043E\u0432,
