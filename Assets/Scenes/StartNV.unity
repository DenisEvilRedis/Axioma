  - beatId: scene7_Start_Vanity
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u041E\u043D \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E \u043F\u0440\u043E\u0448\u0435\u043B
      \u0432\u0433\u043B\u0443\u0431\u044C \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u043D\u043E\u0439
      \u043A \u0441\u0442\u043E\u0439\u043A\u0430\u043C \u0441 \u043A\u043E\u0441\u0442\u044E\u043C\u0430\u043C\u0438.
      \u041F\u0440\u043E\u0449\u0430\u0439, \u043F\u043E\u0442\u0435\u0440\u0442\u0430\u044F
      \u043A\u043E\u0436\u0430 \u0438 \u0434\u044B\u043C; \u0437\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439,
      \u0431\u0435\u0437\u0443\u043F\u0440\u0435\u0447\u043D\u044B\u0439 \u043B\u043E\u0441\u043A. "
    background: {fileID: 21300000, guid: 40bedac795406514caa60c573931f3e6, type: 3}
    musicCueId: 
