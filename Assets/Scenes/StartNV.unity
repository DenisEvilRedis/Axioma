MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1832471129}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1fd17bcf7cc54f37bd52c4f5e1ddc8a1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::VNScene
  sceneId: VNScene_06
  beats:
  - beatId: scene6_after_girl_enter
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u041D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0447\u0430\u0441\u043E\u0432
      \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0442 \u043A\u0430\u043A \u0442\u0435\u043F\u043B\u044B\u0439
      \u0434\u044B\u043C: \u043A\u043E\u0436\u0430, \u0448\u0435\u043F\u043E\u0442,
      \u0441\u043C\u0435\u0445, \u0441\u0432\u0435\u0442 \u0441\u043A\u0432\u043E\u0437\u044C
      \u0448\u0442\u043E\u0440\u044B. \u041F\u043E\u0442\u043E\u043C \u0432\u0441\u0435
      \u043F\u0440\u043E\u0432\u0430\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0432 \u0441\u043E\u043D."
    background: {fileID: 21300000, guid: 393b419c6e57b774db5ea29dbab82a0e, type: 3}
    musicCueId: 
    stopMusic: 0
    nextBeatId: scene6_after_girl_wake
    nextBeatSoundCategoryId: 
    choices: []
    branchRules: []
    defaultNextBeatId: 
    defaultNextBeatSoundCategoryId: 
    onEnterEffects:
      escapeDelta: 0
      vanityDelta: 0
      honestyDelta: 0
      flagsToAdd:
      - scene2_photo_torn
      flagsToRemove: []
    endingToUnlock: 0
  - beatId: scene6_after_girl_wake
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u041C\u0430\u043A\u0441 \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u0435\u0442\u0441\u044F
      \u043E\u0442 \u0437\u0432\u0443\u043A\u0430 \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u043E\u0440\u0430.
      \u0414\u0435\u0432\u0443\u0448\u043A\u0430 \u0441\u0438\u0434\u0438\u0442 \u0432
      \u043A\u0440\u0435\u0441\u043B\u0435 \u0438 \u043B\u0435\u043D\u0438\u0432\u043E
      \u043B\u0438\u0441\u0442\u0430\u0435\u0442 \u043A\u0430\u043D\u0430\u043B\u044B,
      \u0431\u0443\u0434\u0442\u043E \u044D\u0442\u043E \u0443\u0442\u0440\u043E
      \u043D\u0438\u0447\u0435\u043C \u043D\u0435 \u043E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0441\u044F
      \u043E\u0442 \u0434\u0440\u0443\u0433\u0438\u0445."
    background: {fileID: 21300000, guid: 59de74e5af0bbed46ac923a766e54ff1, type: 3}
    musicCueId: 
    stopMusic: 0
    nextBeatId: scene6_after_girl_tv
    nextBeatSoundCategoryId: 
    choices: []
    branchRules: []
    defaultNextBeatId: 
    defaultNextBeatSoundCategoryId: 
    onEnterEffects:
      escapeDelta: 0
      vanityDelta: 0
      honestyDelta: 0
      flagsToAdd:
      - scene2_photo_torn
      flagsToRemove: []
    endingToUnlock: 0
  - beatId: scene6_after_girl_tv
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u041D\u0430 \u044D\u043A\u0440\u0430\u043D\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u0417\u0438\u0440\u0430: \u043F\u043B\u0430\u0442\u0438\u043D\u043E\u0432\u044B\u0439
      \u0431\u043B\u043E\u043D\u0434, \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u0430\u044F
      \u0443\u043B\u044B\u0431\u043A\u0430, \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C,
      \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u043D\u0430\u044F \u0432
      \u043A\u0430\u0436\u0434\u043E\u043C \u0436\u0435\u0441\u0442\u0435."
    background: {fileID: 21300000, guid: 59de74e5af0bbed46ac923a766e54ff1, type: 3}
    musicCueId: 
    stopMusic: 0
    nextBeatId: scene6_after_girl_zira
    nextBeatSoundCategoryId: 
    choices: []
    branchRules: []
    defaultNextBeatId: 
    defaultNextBeatSoundCategoryId: 
    onEnterEffects:
      escapeDelta: 0
      vanityDelta: 0
      honestyDelta: 0
      flagsToAdd:
      - scene2_photo_torn
      flagsToRemove: []
    endingToUnlock: 0
  - beatId: scene6_after_girl_zira
    mode: 0
    speaker: 
    speakerPortrait: 0
    bodyText: "\u0421\u0442\u0430\u0440\u0438\u043A\u0438? \u042F \u0443\u0432\u0430\u0436\u0430\u044E
      \u0438\u0441\u0442\u043E\u0440\u0438\u044E. \u041F\u0440\u0430\u0432\u0434\u0430.
      \u041D\u043E \u0434\u0430\u0432\u0430\u0439\u0442\u0435 \u0447\u0435\u0441\u0442\u043D\u043E:
