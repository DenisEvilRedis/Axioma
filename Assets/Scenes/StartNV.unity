  - beatId: scene3_arthur_voic
    mode: 0
    speaker: "\u0410\u0440\u0442\u0443\u0440"
    speakerPortrait: 2
    bodyText: "\u041C\u0430\u043A\u0441! \u0421\u043B\u0443\u0448\u0430\u0439 \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E.
      \u0417\u0438\u0440\u0430 \u0445\u043E\u0447\u0435\u0442 \u0434\u0443\u044D\u0442.
      \u0421\u044A\u0435\u043C\u043A\u0430 \u0441\u0435\u0433\u043E\u0434\u043D\u044F,
      \u043F\u0430\u0432\u0438\u043B\u044C\u043E\u043D \u043D\u0430 \u041C\u043E\u0441\u0444\u0438\u043B\u044C\u043C\u043E\u0432\u0441\u043A\u043E\u0439,
      \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442 \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043D,
      \u0430\u0432\u0430\u043D\u0441 \u043D\u0430 \u0441\u0447\u0435\u0442\u0443.
      \u0415\u0441\u043B\u0438 \u0442\u044B \u043D\u0435 \u043F\u0440\u0438\u0435\u0434\u0435\u0448\u044C
      \u043A \u0434\u0432\u0443\u043C, \u043E\u043D\u0438 \u0432\u043E\u0437\u044C\u043C\u0443\u0442
      \u0434\u0440\u0443\u0433\u043E\u0433\u043E."
    background: {fileID: 21300000, guid: b8833361eb000a14ebd727772d374d45, type: 3}
